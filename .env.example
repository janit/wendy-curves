# wendy-curves config — copy to .env and edit
WENDY_CURVES_PORT=8087
WENDY_CURVES_DB_PATH=/app/data/wendy-curves.db
WENDY_CURVES_WENDY_URL=http://localhost:8086
# Optional bearer token if wendy is behind auth (mirrors WENDY_SECRET on the wendy side)
# WENDY_CURVES_WENDY_SECRET=
WENDY_CURVES_BOOTSTRAP_HOURS=24
WENDY_CURVES_ARCHIVE_BOOTSTRAP_DAYS=365
WENDY_CURVES_ANALYZER_VERSION=1
WENDY_CURVES_BIN_WIDTH_V=0.5
# Phase 2 — leave 0 for now
WENDY_CURVES_ALLOW_WRITE=0

# Disk-space-triggered pruning
# Starts deleting oldest samples when free disk falls below minFreeGb.
# Respects minRetentionDays as a floor. Runs VACUUM after pruning to
# actually release pages back to the OS.
WENDY_CURVES_PRUNE_ENABLED=1
WENDY_CURVES_PRUNE_MIN_FREE_GB=10
WENDY_CURVES_PRUNE_MIN_RETENTION_DAYS=7
WENDY_CURVES_PRUNE_BATCH_HOURS=6
WENDY_CURVES_PRUNE_CHECK_INTERVAL_MIN=60

# Hardware power ceiling for curve algorithms. Clamps any suggested
# setpoint to at most this value. Default 3000 reflects observed peak
# power at ~160V (rare, in high winds). Previously 5000 (inherited
# from seed curve extrapolation), which was unrealistic.
WENDY_CURVES_MAX_POWER_W=3000
